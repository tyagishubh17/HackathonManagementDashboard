{
  "name": "fairjudge-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\" \"npm run start:ai\" \"npm run start:rag\"",
    "start:frontend": "cd frontend && npm run dev",
    "start:backend": "cd backend && npm run dev",
    "start:ai": "cd ai-service && uvicorn app.main:app --reload --port 8000",
    "start:rag": "cd rag-service && uvicorn app.main:app --reload --port 8001"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
