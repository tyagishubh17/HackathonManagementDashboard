# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets, never commit
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
ai-service/.env

# keep example files so others know what vars are needed
!.env.local.example
!backend/.env.example
!ai-service/.env.example

# Python virtual environments
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo

# Python egg / dist artifacts
*.egg-info/
dist/
build/
.eggs/

# Backend node_modules
backend/node_modules/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
